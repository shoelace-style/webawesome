<wa-button id="github-repo-button" href="{{ site.github.repo }}" rel="noopener noreferrer" target="_blank" appearance="plain" pill>
  <wa-icon family="brands" name="github" label="View Project on GitHub"></wa-icon>
</wa-button>
<wa-tooltip for="github-repo-button" distance="2">View Project on GitHub</wa-tooltip>
<wa-button id="github-star-button" href="{{ site.github.stargazers }}" rel="noopener noreferrer" target="_blank" appearance="plain" pill>
  <wa-icon name="star" variant="regular" label="Star Project on GitHub"></wa-icon>
</wa-button>
<wa-tooltip for="github-star-button" distance="2">Star Project on GitHub</wa-tooltip>
