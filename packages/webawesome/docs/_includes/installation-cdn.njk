{# CDN: Pro with projects #}
{% if currentUser.hasPro and data.projects and data.projects.length > 0 %}
  {% set firstProject = data.projects[0] %}

  <div id="installation-cdn-pro">
    {% if data.projects.length > 1 %}
    <wa-select id="installation-project-selector" label="Projects in {{ currentUser.currentWorkspace.name }}" value="{{ firstProject.webawesomeKitCode }}" size="small" style="margin-block-end: 0.25rem;">
      {% for project in data.projects %}
      <wa-option value="{{ project.webawesomeKitCode }}">{{ project.name }}</wa-option>
      {% endfor %}
    </wa-select>
    <div style="margin-block-end: 1rem;">
      <small><a href="#">Select a different workspace</a></small>
    </div>
    {% else %}
    <p>
      <strong>{{ currentUser.currentWorkspace.name }}:</strong> {{ firstProject.name }}
    </p>
    <small><a href="#">Select a different workspace</a></small>
    {% endif %}

    {# Render a code block per project, show/hide based on selection #}
    {% for project in data.projects %}
    <div class="installation-cdn-project-code" data-kit-code="{{ project.webawesomeKitCode }}" {% if loop.index0 > 0 %}hidden{% endif %}>
      <pre><code class="language-html">&lt;link rel="stylesheet" href="https://ka-p.webawesome.com/kit/{{ project.webawesomeKitCode }}/webawesome@{{ version }}/styles/webawesome.css"&gt;
&lt;script type="module" src="https://ka-p.webawesome.com/kit/{{ project.webawesomeKitCode }}/webawesome@{{ version }}/webawesome.loader.js"&gt;&lt;/script&gt;</code></pre>
    </div>
    {% endfor %}
  </div>

  <script type="module">
    function initProjectSelector() {
      const selector = document.getElementById('installation-project-selector');
      const codeBlocks = document.querySelectorAll('.installation-cdn-project-code');

      if (!codeBlocks.length) return;

      function showProject(kitCode) {
        codeBlocks.forEach(block => {
          block.hidden = block.dataset.kitCode !== kitCode;
        });
      }

      // Restore from sessionStorage
      const stored = sessionStorage.getItem('wa-docs-selected-project');
      if (stored) {
        const match = [...codeBlocks].find(block => block.dataset.kitCode === stored);
        if (match) {
          showProject(stored);
          if (selector) {
            customElements.whenDefined('wa-select').then(() => {
              selector.value = stored;
            });
          }
        }
      }

      if (selector) {
        selector.addEventListener('change', (e) => {
          const kitCode = e.target.value;
          sessionStorage.setItem('wa-docs-selected-project', kitCode);
          showProject(kitCode);
        });
      }
    }

    // Run on initial load
    initProjectSelector();

    // Run on Turbo navigation
    if (!window.__installationSelectorAttached) {
      window.__installationSelectorAttached = true;
      document.addEventListener('turbo:load', initProjectSelector);
    }
  </script>

{# CDN: Pro with no projects #}
{% elseif currentUser.hasPro and (not data.projects or data.projects.length === 0) %}
  <pre><code class="language-html">&lt;link rel="stylesheet" href="https://ka-f.webawesome.com/webawesome@{{ version }}/styles/webawesome.css"&gt;
&lt;script type="module" src="https://ka-f.webawesome.com/webawesome@{{ version }}/webawesome.loader.js"&gt;&lt;/script&gt;</code></pre>

  <wa-callout>
    <wa-icon slot="icon" name="circle-info"></wa-icon>
    Want to use the Pro CDN with custom themes and settings? <a href="/workspaces">Create a project</a> in your workspace to get a personalized Pro CDN URL.
  </wa-callout>

{# CDN: Free / logged out #}
{% else %}
  <pre><code class="language-html">&lt;link rel="stylesheet" href="https://ka-f.webawesome.com/webawesome@{{ version }}/styles/webawesome.css"&gt;
&lt;script type="module" src="https://ka-f.webawesome.com/webawesome@{{ version }}/webawesome.loader.js"&gt;&lt;/script&gt;</code></pre>

  {% if not session.isLoggedIn %}
  <p>
    <a href="/signup">Sign up</a> or <a href="/login">log in</a> to unlock Pro features including custom themes, additional components, and more.
  </p>
  {% endif %}
{% endif %}
