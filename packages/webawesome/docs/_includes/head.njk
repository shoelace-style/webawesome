<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="{{ description }}">
{% if noindex %}<meta name="robots" content="noindex">{% endif %}

<title>{{ pageTitle }}</title>

<link rel="canonical" href="{{ ogUrl }}" />

{# Skip OG tags for noindex pages to prevent social sharing #}
{% if not noindex %}
  <meta property="og:type" content="{{ ogType }}" />
  <meta property="og:url" content="{{ ogUrl }}" />
  <meta property="og:title" content="{{ ogTitle }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  <meta property="og:image" content="{{ ogImage }}" />
  {% if ogImageWidth %}<meta property="og:image:width" content="{{ ogImageWidth }}" />{% endif %}
  {% if ogImageHeight %}<meta property="og:image:height" content="{{ ogImageHeight }}" />{% endif %}
  <meta property="og:site_name" content="{{ siteMetadata.name }}" />
  <meta name="twitter:card" content="summary_large_image" />
{% endif %}

{# Dark mode #}
<script>
	let colorScheme = localStorage.colorScheme;
	let isDark = localStorage.colorScheme === "dark";
	if (!colorScheme || colorScheme === "auto") {
		isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
	}
	document.documentElement.classList.toggle('wa-dark', isDark);

  function setCookie(options) {
    let {
      name,
      value,
      maxAge,
      sameSite,
      path,
    } = options

    if (!sameSite) { sameSite = "Lax" }
    if (maxAge == null) {
      maxAge = 60 * 60 * 24 * 365; // 1 year
    }
    if (!path) { path = "/" }

    document.cookie = `${encodeURIComponent(name)}=${encodeURIComponent(value)}; path=${path}; max-age=${maxAge}; SameSite=${sameSite}`;
  }

  function removeCookie(options) {
    let {name, path} = options
    if (!path) { path = "/" }
    document.cookie = `${encodeURIComponent(name)}=; path=${path}; max-age=0`;
  }
</script>

{# TODO: Figure out how to only load in dev #}
{% raw %}
  {% if isDev %}
    <script src="/assets/scripts/hydration-errors.js"></script>
    <link rel="stylesheet" href="/assets/styles/hydration-errors.css">
  {% endif %}
{% endraw %}

<link rel="manifest" href="/manifest.json" />
<link rel="icon" href="/assets/images/app-icons/favicon.ico" sizes="any">
<link rel="icon" href="/assets/images/app-icons/icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/assets/images/app-icons/apple-touch-icon.png">

<link rel="preconnect" href="https://cdn.jsdelivr.net">
<script type="module" src="/dist/webawesome.ssr-loader.js"></script>
<link rel="preload" as="font" type="font/woff2" href="/assets/fonts/cera-round-pro-400.woff2" crossorigin>
{% if pageClass == 'home' %}
  <link rel="preload" as="image" type="image/svg+xml" href="/assets/images/bg-wa-pattern-light.svg" media="(prefers-color-scheme: light)">
  <link rel="preload" as="image" type="image/svg+xml" href="/assets/images/bg-wa-pattern-dark.svg" media="(prefers-color-scheme: dark)">
{% endif %}

{# Load themes from cookies so that we can give a proper SSR feel. #}
{% raw %}
  {% if req.cookies.webawesome_theme %}
    <link id="theme-stylesheet" rel="stylesheet" href="/dist/styles/themes/{{ req.cookies.webawesome_theme }}.css" render="blocking" fetchpriority="high" />
  {% else %}
    <link id="theme-stylesheet" rel="stylesheet" href="/dist/styles/themes/default.css" render="blocking" fetchpriority="high" />
  {% endif %}
{% endraw %}

<link rel="stylesheet" href="/dist/styles/webawesome.css" />

<script type="module">
  document.addEventListener('wa-discovery-complete', loadLayout)
  function loadLayout () {
    const proComponents = [
      "combobox",
    ]

    const kitCode = "f4ea8aaaeb9d4f12"

    const define = window.customElements.define
    window.customElements.define = function (tagName, ctor, options) {
      // We may get duplicate registrations from pro components (popover, button, etc) loaded from CDN so ignore duplicate registrations.
      if (window.customElements.get(tagName)) {
        return
      }

      return define.call(this, tagName, ctor, options)
    }

    // This is really hacky and only for running the free repo locally. Its not perfect, but its better than nothing.
    // This will break singletons, and cause things to load twice
    const toLoad = proComponents.filter((tagName) => {
      // Make sure the pro component is actually being used on the page.
      return !customElements.get("wa-" + tagName) && document.querySelector("wa-" + tagName)
    })

    if (toLoad.length > 0) {
      // The CDN bundle ships its own copy of Lit. Our local SSR loader installs a
      // global `litElementHydrateSupport` hook that lit-element invokes at module
      // eval time — if it's still present when the CDN bundle evaluates, it patches
      // the CDN's LitElement to hydrate through OUR lit-html copy, mixing two Lit
      // instances and throwing `_$initialize is not a function`. These pro
      // components are client-only (never SSR'd locally), so suppress the hook while
      // the CDN bundles evaluate, then restore it.
      const savedHydrateSupport = globalThis.litElementHydrateSupport
      delete globalThis.litElementHydrateSupport

      const imports = toLoad.map((tagName) =>
        import(`https://ka-p.webawesome.com/kit/${kitCode}/webawesome@{{ package.version }}/components/${tagName}/${tagName}.js`)
          .catch((e) => {
            // known errors with dual registration. This is only a thing in the free repo.
          })
      )

      Promise.allSettled(imports).finally(() => {
        if (savedHydrateSupport) globalThis.litElementHydrateSupport = savedHydrateSupport
      })
    }
  }
</script>

{# Used by Web Awesome App to inject other assets into the head. #}
{% server "head" %}
