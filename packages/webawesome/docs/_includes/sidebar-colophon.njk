<div class="wa-stack wa-gap-xl" id="colophon">
  <div class="wa-stack wa-gap-xs">
    <wa-icon name="web-awesome" family="brands" class="logo-web-awesome"></wa-icon>
    <h2 class="wa-heading-s">{{ site.name }}</h2>
    <span class="wa-caption-xs">
      v{{ package.version }}
    </span>
    <span class="wa-caption-xs">
      Go make something awesome
    </span>
    <span class="wa-caption-xs">
      &copy; {{ site.company }}
    </span>
  </div>

  <div class="wa-cluster wa-gap-0 wa-caption-s the-socials">
    <h2 class="wa-visually-hidden">{{ site.name }} Elsewhere</h2>
    <a href="{{ site.github.repo }}" rel="noopener noreferrer" target="_blank"
      class="appearance-plain">
      <wa-icon family="brands" name="github" label="GitHub"></wa-icon>
    </a>
    <a href="{{ site.urls.discord }}" rel="noopener noreferrer" target="_blank"
      class="appearance-plain">
      <wa-icon family="brands" name="discord" label="Discord"></wa-icon>
    </a>
    <a href="{{ site.urls.bluesky }}" rel="noopener noreferrer" target="_blank"
      class="appearance-plain">
      <wa-icon family="brands" name="bluesky" label="Bluesky"></wa-icon>
    </a>
    <a href="{{ site.urls.mastodon }}" rel="noopener noreferrer" target="_blank" class="appearance-plain">
      <wa-icon family="brands" name="mastodon" label="Mastodon"></wa-icon>
    </a>
    <a href="{{ site.urls.x }}" rel="noopener noreferrer" target="_blank" class="appearance-plain">
      <wa-icon family="brands" name="x-twitter" label="Twitter (X)"></wa-icon>
    </a>
    <a href="{{ site.urls.threads }}" rel="noopener noreferrer" target="_blank" class="appearance-plain">
      <wa-icon family="brands" name="threads" label="Threads"></wa-icon>
    </a>
  </div>
</div>
