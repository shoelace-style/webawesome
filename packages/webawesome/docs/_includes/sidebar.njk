<div class="wa-stack wa-gap-xs wa-mobile-only">
  {% include "search-trigger-button.njk" %}
  <div class="wa-split">
    {% include "ssr-switch.njk" %}
    <div class="wa-cluster wa-gap-3xs wa-flex-nowrap">
      {% include "color-scheme-selector.njk" %}
      {% if hasThemeSelector %}
        {% include "theme-selector.njk" %}
      {% endif %}
    </div>
  </div>
</div>
{% from "pro-badge.njk" import proBadge %}
{% from "planned-badge.njk" import plannedBadge %}

{%- macro sidebarComponent(page, suppressProBadge=false) -%}
  {%- set component = page.data.component -%}
  {%- set isExperimental = component and component.status == 'experimental' -%}
  {%- set isPro = page.data.isProComponent and not suppressProBadge -%}
  {%- if isPro %}<span class="wa-split">{% endif -%}
  <a{% if isExperimental %} class="wa-cluster wa-gap-xs"{% endif %} href="{{ page.url }}">{{ page.data.title }}{% if isExperimental %} <wa-icon name="flask" aria-hidden="true" class="icon-shrink de-emphasize"></wa-icon>{% endif %}</a>
  {%- if isPro %} {{ proBadge() }}</span>{% endif -%}
{%- endmacro %}

{%- set sortedComponentPages = collections.componentPages | sort(false, false, 'data.title') -%}

<div class="wa-stack wa-gap-xl">
  <section class="wa-stack">
    <h2 class="wa-cluster wa-gap-xs">
      <wa-icon name="wand-magic-sparkles" variant="regular" aria-hidden="true"></wa-icon>
      Getting Started
    </h2>
    <ul>
      <li><a href="/docs">Installation</a></li>
      <li><a href="/docs/usage">Usage</a></li>
      <li><a href="/docs/form-controls">Forms</a></li>
      <li><a href="/docs/localization">Localization</a></li>
      <li><a href="/docs/frameworks/">Frameworks</a></li>
      <li><a href="/docs/ai">Using with AI</a></li>
      <li>
        <span class="wa-split">
          <a href="/docs/resources/figma">Figma Design Kit</a>
          {{ proBadge() }}
        </span>
      </li>
      <li>
        <a class="wa-cluster wa-gap-xs" href="/docs/ssr">
          Server Rendering
          <wa-icon name="flask" aria-hidden="true" class="icon-shrink de-emphasize"></wa-icon>
        </a>
      </li>
    </ul>
  </section>

  <section class="wa-stack">
    <h2 class="wa-cluster wa-gap-xs">
      <wa-icon name="book-spine" variant="regular" aria-hidden="true"></wa-icon>
      Resources
    </h2>
    <ul>
      <li><a href="/docs/resources/accessibility">Accessibility</a></li>
      <li><a href="/docs/resources/browser-support">Browser Support</a></li>
      <li><a href="/docs/resources/contributing">Contributing</a></li>
      <li>
        <span class="wa-split">
          <a href="/docs/patterns/">Patterns</a>
          {{ proBadge({ description: "Patterns require access to " ~ site.namePro }) }}
        </span>
      </li>
      <li><a href="/docs/resources/migrating-from-shoelace">Migrating from Shoelace</a></li>
      <li><a href="/docs/resources/visual-tests">Visual Tests</a></li>
      <li><a href="/docs/resources/changelog">Changelog</a></li>
      <li><a href="{{ site.urls.support }}">Help & Support</a></li>
    </ul>
  </section>

  <section class="wa-stack">
    <h2 class="wa-cluster wa-gap-xs">
      <wa-icon name="palette" variant="regular" aria-hidden="true"></wa-icon>
      Theming &amp; Utilities
    </h2>
    <ul>
      <li><a href="/docs/theming-overview">Overview</a></li>
      <li><a href="/docs/themes">Built-in Themes</a></li>
      <li><a href="/docs/color-palettes">Color Palettes</a></li>
      <li><a href="/docs/tokens/">Design Tokens</a></li>
      <li><a href="/docs/customizing">Customizing &amp; Theming</a></li>
      <li><a href="/docs/utilities/">CSS Utilities</a></li>
    </ul>
  </section>

  {# Components — auto-organized by category. Categories defined in _data/componentCategories.json. #}
  {# Each component's `.md` front matter drives placement: `category` chooses the section, optional `parent` nests it under another component, optional `sidebarHidden` skips it. #}
  {% for cat in componentCategories %}
  {%- set categoryPages = [] -%}
  {%- for page in sortedComponentPages -%}
    {%- if page.data.category == cat.label and not page.data.parent and not page.data.sidebarHidden -%}
      {%- set _ = categoryPages.push(page) -%}
    {%- endif -%}
  {%- endfor -%}
  {%- set categoryIsAllPro = categoryPages.length > 0 -%}
  {%- for page in categoryPages -%}
    {%- if not page.data.isProComponent -%}{%- set categoryIsAllPro = false -%}{%- endif -%}
  {%- endfor -%}
  <section class="wa-stack">
    <h2 class="wa-split">
      <span class="wa-cluster wa-gap-xs">
        <wa-icon name="{{ cat.icon }}" variant="regular" aria-hidden="true"></wa-icon>
        {{ cat.label }}
      </span>
      {% if categoryIsAllPro %}{{ proBadge() }}{% endif %}
    </h2>
    <ul>
    {%- for page in categoryPages %}
      <li>
        {{ sidebarComponent(page, categoryIsAllPro) }}
        {%- set children = [] -%}
        {%- for child in sortedComponentPages -%}
          {%- if child.data.parent == page.fileSlug and not child.data.sidebarHidden -%}
            {%- set _ = children.push(child) -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if children.length %}
        <ul>
        {%- for child in children %}
          <li>{{ sidebarComponent(child, categoryIsAllPro) }}</li>
        {%- endfor %}
        </ul>
        {%- endif %}
      </li>
    {%- endfor %}
    {%- if cat.slug == 'forms' %}
      <li><span class="is-planned wa-split">Data Grid <span>{{ plannedBadge("A Web Awesome Kickstarter stretch goal!") }}</span></span></li>
    {%- elif cat.slug == 'data-viz' %}
      <li><a href="/docs/components/chart">Advanced Usage</a></li>
    {%- endif %}
    </ul>
  </section>
  {% endfor %}
</div>
