{# Components — auto-organized by category. Categories defined in _data/componentCategories.json. #}
{# Each component's `.md` front matter drives placement: `category` chooses the section, optional `parent` nests it under another component, optional `sidebarHidden` skips it. #}
{%- set sortedComponentPages = collections.componentPages | sort(false, false, 'data.title') -%}

{%- macro sidebarComponent(page) -%}
  {%- set component = page.data.component -%}
  {%- set isExperimental = component and component.status == 'experimental' -%}
  {%- set isPro = page.data.isProComponent -%}
  {%- if isPro %}<span class="wa-split">{% endif -%}
  <a{% if isExperimental %} class="wa-cluster wa-gap-xs"{% endif %} href="{{ page.url }}">{{ page.data.title }}{% if isExperimental %} <wa-icon name="flask" aria-hidden="true" class="icon-shrink de-emphasize"></wa-icon>{% endif %}</a>
  {%- if isPro %} {{ proBadge() }}</span>{% endif -%}
{%- endmacro %}

{% for cat in componentCategories %}
<!-- {{ cat.label }} -->
<h2 class="wa-cluster wa-gap-xs">
  <wa-icon name="{{ cat.icon }}" variant="regular" aria-hidden="true"></wa-icon>
  {{ cat.label }}
</h2>
<ul>
{%- for page in sortedComponentPages -%}
  {%- if page.data.category == cat.label and not page.data.parent and not page.data.sidebarHidden %}
  <li>
    {{ sidebarComponent(page) }}
    {%- set children = [] -%}
    {%- for child in sortedComponentPages -%}
      {%- if child.data.parent == page.fileSlug and not child.data.sidebarHidden -%}
        {%- set _ = children.push(child) -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if children.length %}
    <ul>
    {%- for child in children %}
      <li>{{ sidebarComponent(child) }}</li>
    {%- endfor %}
    </ul>
    {%- endif %}
  </li>
  {%- endif -%}
{%- endfor %}
{%- if cat.slug == 'forms' %}
  <li><span class="is-planned wa-split">Data Grid <span>{{ plannedBadge("A Web Awesome Kickstarter stretch goal!") }}</span></span></li>
{%- elif cat.slug == 'data-viz' %}
  <li><a href="/docs/components/chart">Advanced Usage</a></li>
{%- endif %}
</ul>
{% endfor %}
