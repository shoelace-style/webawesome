{% raw %}
{% if isBuildAwesomePromoActive %}
<div slot="banner" class="wrapper-banner">
  <wa-callout appearance="accent" variant="brand" class="banner banner-ba-kickstarter brand-build-awesome">
    <wa-icon slot="icon" name="party-horn" family="duotone" variant="solid" class="banner-icon"></wa-icon>
    <div class="wa-flank:end">
      <p><strong class="brand-font" style="margin-inline-end: var(--wa-space-2xs)">Build Awesome has landed!</strong> A new way to build fast, beautiful websites with endless 'possum-bilities. </p>
      <wa-button appearance="accent" variant="neutral" size="s" href="https://www.kickstarter.com/projects/fontawesome/build-awesome?ref=9x1kgb" class="brand-font">
        <wa-icon slot="start" src="/assets/images/logo-build-awesome-icon.svg" style="--logo-icon-fill: currentColor;"></wa-icon>
        Back the Kickstarter!
      </wa-button>
    </div>
  </wa-callout>
</div>
{% endif %}
{% endraw %}
