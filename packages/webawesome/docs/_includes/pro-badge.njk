{%- macro proBadge(params) -%}
{%- set description = params and params.description or "This requires access to Web Awesome Pro" -%}
{%- set badgeId = params and params.id or ("pro-badge-" + ("" | uniqueId(8))) -%}
<wa-badge appearance="accent" pill class="pro" id="{{ badgeId }}" data-pro-badge>Pro</wa-badge><wa-tooltip for="{{ badgeId }}">{{ description }}</wa-tooltip>
{%- endmacro -%}
