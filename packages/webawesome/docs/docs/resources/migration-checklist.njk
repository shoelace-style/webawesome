</section>

<section data-checklist-section="test">
  <h2>7. Testing</h2>

  <wa-checkbox data-checklist-item="test-build">Production build succeeds</wa-checkbox>
  <wa-checkbox data-checklist-item="test-typecheck">TypeScript type-check passes (catches event class import
