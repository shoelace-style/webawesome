</section>

<section data-checklist-section="follow-ups">
  <h2>8. Optional Follow-Ups</h2>

  <wa-checkbox data-checklist-item="followup-theme-switch">Adopted <code>wa-theme-shoelace</code> initially? Consider
    switching to <code>default</code> or <code>awesome</code></wa-checkbox>
  <wa-checkbox data-checklist-item="followup-utilities">Tried the new utility classes (<code>wa-cluster</code>,
    <code>wa-stack</code>, <code>wa-grid</code>, etc.) to replace custom layout CSS</wa-checkbox>
  <wa-checkbox data-checklist-item="followup-page">Tried <code>&lt;wa-page&gt;</code> for app shell layout</wa-checkbox>
  <wa-checkbox data-checklist-item="followup-popover">Tried <code>&lt;wa-popover&gt;</code> where you previously used a
    tooltip with rich content</wa-checkbox>
  <wa-checkbox data-checklist-item="followup-number-input">Tried <code>&lt;wa-number-input&gt;</code> instead of
    <code>&lt;wa-input type="number"&gt;</code></wa-checkbox>
  <wa-checkbox data-checklist-item="followup-pro">Evaluated Web Awesome Pro for <code>&lt;wa-toast&gt;</code>,
    <code>&lt;wa-combobox&gt;</code>, <code>&lt;wa-file-input&gt;</code>, charts, sparklines, additional
    themes</wa-checkbox>
</section>

<style>
  wa-card#checklist-toolbar {
    --spacing: var(--wa-space-s);
  }

  #checklist-toolbar.checklist-toolbar {
    position: sticky;
    /* Clear the sticky wa-page header and subheader so the toolbar isn't covered. */
    inset-block-start: calc(var(--header-height, 0px) + var(--subheader-height, 0px) + .25rem);
    z-index: 1;
    /* Slight breakout so the toolbar feels like its own UI surface, not body text. */
    margin-inline: calc(-1 * var(--wa-space-m));
    margin-block: var(--wa-space-l);
    padding-block: var(--wa-space-s);
    padding-inline: var(--wa-space-m);
    background-color: var(--wa-color-surface-default);
    border: var(--wa-border-width-s) solid var(--wa-color-surface-border);
    border-radius: var(--wa-border-radius-m);
    box-shadow: var(--wa-shadow-s);
  }

  #checklist-toolbar .checklist-toolbar-count {
    margin-block: 0;
    margin-inline: 0;
    flex: 0 0 auto;
    max-inline-size: 100%;
  }

  /* Progress row: alignment + wrap come from wa-cluster; only progress-bar flex sizing is custom. */
  #checklist-toolbar .checklist-toolbar-progress wa-progress-bar {
    flex: 1 1 12rem;
    min-inline-size: 12rem;
  }

  @media (max-inline-size: 36rem) {
    #checklist-toolbar .checklist-toolbar-progress {
      flex-direction: column;
      align-items: stretch;
    }

    #checklist-toolbar .checklist-toolbar-progress wa-progress-bar {
      flex: 1 1 auto;
      min-inline-size: 0;
      inline-size: 100%;
    }

    #checklist-toolbar .checklist-toolbar-actions {
      flex-direction: column;
      align-items: stretch;
    }

    #checklist-toolbar .checklist-toolbar-actions wa-button {
      inline-size: 100%;
    }

    /* Toolbar footer uses slot="footer" + wa-grid when actions moved out of .checklist-toolbar-actions */
    #checklist-toolbar [slot='footer'] wa-button {
      inline-size: 100%;
    }
  }

  #content section[data-checklist-section] {
    margin-block: var(--wa-space-xl);
  }

  #content section[data-checklist-section] h3 {
    margin-block-start: var(--wa-space-l);
  }

  /* Full-width rows without overriding host display:inline-flex on wa-checkbox. */
  #content wa-checkbox[data-checklist-item] {
    box-sizing: border-box;
    inline-size: 100%;
    max-inline-size: 100%;
    margin-block: var(--wa-space-xs);
  }

  /* Long import paths: nowrap forced huge main min-content; wrap instead of one long line. */
  #content wa-checkbox[data-checklist-item] code {
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  /* Dim completed items so users can see what's left at a glance. */
  #content wa-checkbox[data-checklist-item][checked] {
    opacity: 0.55;
    transition: opacity var(--wa-transition-normal);
  }

  @media (prefers-reduced-motion: reduce) {
    #content wa-checkbox[data-checklist-item][checked] {
      transition: none;
    }
  }
</style>

<script type="module">
  const STORAGE_KEY = 'wa-migration-checklist-v1';
  const items = document.querySelectorAll('wa-checkbox[data-checklist-item]');
  const progressBar = document.getElementById('checklist-progress-bar');
  const progressLabel = document.getElementById('checklist-progress-label');
  const resetButton = document.getElementById('checklist-reset');

  const loadState = () => {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY)) ?? {};
    } catch {
      return {};
    }
  };

  const saveState = (state) => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch {
      // Storage may be disabled (private mode, quota). Fail silently; the page still works as a session-local checklist.
    }
  };

  const updateProgress = () => {
    const total = items.length;
    const done = [...items].filter(item => item.checked).length;
    const pct = total === 0 ? 0 : Math.round((done / total) * 100);
    progressBar.value = pct;
    progressLabel.textContent = `${done} of ${total} complete (${pct}%)`;
  };

  const restore = () => {
    const state = loadState();
    items.forEach(item => {
      const id = item.dataset.checklistItem;
      if (state[id]) item.checked = true;
    });
    updateProgress();
  };

  const onChange = (event) => {
    const item = event.target.closest('wa-checkbox[data-checklist-item]');
    if (!item) return;
    const state = loadState();
    const id = item.dataset.checklistItem;
    if (item.checked) {
      state[id] = true;
    } else {
      delete state[id];
    }
    saveState(state);
    updateProgress();
  };

  const onReset = () => {
    if (!confirm('Reset all checklist progress? This cannot be undone.')) return;
    items.forEach(item => { item.checked = false; });
    saveState({});
    updateProgress();
  };

  // Web Awesome checkboxes upgrade asynchronously. Wait for them before reading state.
  customElements.whenDefined('wa-checkbox').then(() => {
    restore();
    items.forEach(item => item.addEventListener('change', onChange));
  });

  resetButton.addEventListener('click', onReset);
</script>
