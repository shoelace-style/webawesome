<script type="module">
  // ─── Search ───────────────────────────────────────────────────────────────
  const searchInput = document.getElementById('token-search');
  const searchResults = document.getElementById('token-search-results');
  const resultsBody = document.getElementById('token-results-body');
  const noResults = document.getElementById('token-no-results');

  // Build index by reading directly from table cell content
  function buildIndex() {
    return Array.from(document.querySelectorAll('.token-table tbody tr[id]')).map(row => ({
      name: row.querySelector('td:first-child code')?.textContent.trim() ?? '',
      desc: row.querySelector('td:nth-child(2)')?.textContent.trim() ?? '',
      category: row.closest('wa-tab-panel')?.getAttribute('name') ?? '',
      id: row.id,
    }));
  }

  const categoryLabels = {
    color: 'Color',
    typography: 'Typography',
    space: 'Space',
    borders: 'Borders',
    shadows: 'Shadows',
    focus: 'Focus',
    transitions: 'Transitions',
    components: 'Components',
  };

  function navigateToToken(tokenId, category) {
    // Clear search
    searchInput.value = '';
    searchResults.hidden = true;
    resultsBody.innerHTML = '';

    // Show the right tab
    const tabMap = {
      color: 'color',
      typography: 'typography',
      space: 'space',
      borders: 'borders',
      shadows: 'shadows',
      focus: 'focus',
      transitions: 'transitions',
      components: 'components',
    };
    const tab = tabMap[category] || category;
    tokenTabs.show(tab);

    requestAnimationFrame(() => requestAnimationFrame(() => {
      const row = document.getElementById(tokenId);
      if (!row) return;
      row.scrollIntoView({ behavior: 'smooth', block: 'center' });
      row.classList.remove('token-row-highlight');
      // Force reflow to restart animation
      void row.offsetWidth;
      row.classList.add('token-row-highlight');
      row.addEventListener('animationend', () => row.classList.remove('token-row-highlight'), { once: true });
    }));
  }

  function renderResults(query) {
    const q = query.trim().toLowerCase();
    if (!q) {
      searchResults.hidden = true;
      resultsBody.innerHTML = '';
      return;
    }

    const index = buildIndex();
    const matches = index.filter(t =>
      t.name.toLowerCase().includes(q) ||
      t.desc.toLowerCase().includes(q) ||
      t.category.toLowerCase().includes(q)
    );

    resultsBody.innerHTML = '';
    if (matches.length === 0) {
      noResults.hidden = false;
      searchResults.hidden = false;
      return;
    }

    noResults.hidden = true;
    matches.forEach(token => {
      const tr = document.createElement('tr');
      tr.style.cursor = 'pointer';
      tr.title = 'Jump to token';
      tr.innerHTML = `
        <td><span class="cat-badge cat-badge-${token.category}">${categoryLabels[token.category] || token.category}</span></td>
        <td class="token-name"><code>${token.name}</code></td>
        <td>${token.desc}</td>
      `;
      tr.addEventListener('click', () => navigateToToken(token.id, token.category));
      resultsBody.appendChild(tr);
    });

    searchResults.hidden = false;
  }

  searchInput.addEventListener('input', e => renderResults(e.target.value));

  // "/" shortcut to focus search
  document.addEventListener('keydown', e => {
    if (e.key === '/' && document.activeElement !== searchInput && !['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName)) {
      e.preventDefault();
      searchInput.focus();
      searchInput.select();
    }
  });

</script>
