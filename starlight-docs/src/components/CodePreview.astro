---
import { highlight } from '../utilities/prism.js';
import dedent from 'dedent';

const code = dedent`${Astro.props.code}`;
const reactCode = dedent`${Astro.props.react}`;
const expanded = Boolean(Astro.props.expanded);
const highlightedCode = highlight('html', code);
const highlightedReactCode = highlight('jsx', reactCode);
---

<div class="code-preview not-content" class:list={[{ expanded }]}>
  <div class="preview">
    <div set:html={code} />

    <div class="resizer">
      <wa-icon name="grip-lines-vertical" aria-hidden="true" library="default"></wa-icon>
    </div>
  </div>

  <div class="source-group" id="code-preview-source-group-52">
    <pre class="source source-html"><code class="language-html" set:html={highlightedCode} /></pre>
    <pre class="source source-react"><code class="language-jsx" set:html={highlightedReactCode} /></pre>
  </div>

  <div class="buttons">
    <button type="button" class="button button-source" aria-expanded="true" aria-controls="code-preview-source-group-52">
      Source
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>

    <button type="button" class="button button-html" title="Show HTML code">
      HTML
    </button>

    <button type="button" class="button button-react" title="Show React code">
      React
    </button>

    <button type="button" class="button button-codepen" title="Edit on CodePen">
      <svg
        width="138"
        height="26"
        viewBox="0 0 138 26"
        fill="none"
        stroke="currentColor"
        stroke-width="2.3"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M80 6h-9v14h9 M114 6h-9 v14h9 M111 13h-6 M77 13h-6 M122 20V6l11 14V6 M22 16.7L33 24l11-7.3V9.3L33 2L22 9.3V16.7z M44 16.7L33 9.3l-11 7.4 M22 9.3l11 7.3 l11-7.3 M33 2v7.3 M33 16.7V24 M88 14h6c2.2 0 4-1.8 4-4s-1.8-4-4-4h-6v14 M15 8c-1.3-1.3-3-2-5-2c-4 0-7 3-7 7s3 7 7 7 c2 0 3.7-0.8 5-2 M64 13c0 4-3 7-7 7h-5V6h5C61 6 64 9 64 13z"
        ></path>
      </svg>
    </button>
  </div>
</div>

<script>
  // console.log('byah');
</script>

<style is:global>
  /* Interactive preview */
  .preview {
    position: relative;
    border: var(--wa-border-style) var(--wa-border-width-thin) var(--sl-color-gray-6);
    border-top-left-radius: var(--wa-corners-s);
    border-top-right-radius: var(--wa-corners-s);
    padding: 1rem;
  }

  /* Source code */
  [data-theme="dark"] .source,
  [data-theme="light"] .source {
    font-size: var(--sl-text-sm);
    border-left: var(--wa-border-style) var(--wa-border-width-thin) var(--sl-color-gray-6);
    border-right: var(--wa-border-style) var(--wa-border-width-thin) var(--sl-color-gray-6);
    border-radius: 0;
    padding: var(--wa-space-m);
  }

  /* Resizer */
  .resizer {
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 1.75rem;
    color: var(--wa-color-text-quiet);
    background-color: var(--wa-color-surface-default);
    border-left: var(--wa-border-style) var(--wa-border-width-thin) var(--wa-color-surface-border);
    border-top-right-radius: var(--wa-corners-s);
    cursor: ew-resize;
  }

  @media screen and (max-width: 600px) {
    .preview {
      padding-right: var(--wa-space-xl);
    }

    .resizer {
      display: none;
    }
  }

  /* Buttons */
  .buttons {
    position: relative;
    border: var(--wa-border-style) var(--wa-border-width-thin) var(--wa-color-surface-border);
    border-bottom-left-radius: var(--wa-corners-s);
    border-bottom-right-radius: var(--wa-corners-s);
    display: flex;
  }

  .button {
    flex: 0 0 auto;
    height: 2.5rem;
    min-width: 2.5rem;
    border: none;
    border-radius: 0;
    background: var(--wa-color-surface-default);
    font: inherit;
    font-size: var(--wa-font-size-xs);
    font-weight: var(--wa-font-weight-normal);
    text-transform: uppercase;
    color: var(--wa-color-text-quiet);
    padding: 0 1rem;
    cursor: pointer;
  }

  .button:not(:last-of-type) {
    border-right: var(--wa-border-style) var(--wa-border-width-thin) var(--wa-color-surface-border);
  }

  .button-html,
  .button-react {
    width: 70px;
    display: flex;
    place-items: center;
    justify-content: center;
  }

  .button-selected {
    font-weight: var(--wa-font-weight-heavy);
    color: var(--wa-color-brand-text-on-surface);
  }

  .button-codepen {
    display: flex;
    place-items: center;
    width: 6rem;
  }

  .button:first-of-type {
    border-bottom-left-radius: var(--wa-corners-s);
  }

  .button:last-of-type {
    border-bottom-right-radius: var(--wa-corners-s);
  }

  .button:hover,
  .button:active {
    box-shadow: 0 0 0 var(--wa-border-width-thin) var(--wa-color-brand-border-subtle);
    border-right-color: transparent;
    background-color: var(--wa-color-brand-fill-subtle);
    color: var(--wa-color-brand-text-on-surface);
    z-index: 1;
  }

  .button:focus-visible {
    outline: none;
    outline: var(--wa-focus-ring);
    z-index: 2;
  }

  .button-source {
    position: relative;
    display: flex;
    flex: 1 1 auto;
    align-items: center;
    justify-content: center;
    width: 100%;
    color: var(--wa-color-text-quiet);
    cursor: pointer;
  }

  .button-source svg {
    width: 1em;
    height: 1em;
    margin-left: 0.25rem;
  }


