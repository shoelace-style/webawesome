{
  "headers": [
    {
      "source": "/:path*.js",
      "has": [
        {
          "type": "query",
          "key": "authorized"
        }
      ],
      "headers": [
        {
          "key": "x-authorized",
          "value": "true"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "script"
        },
        {
          "key": "X-Frame-Options",
          "value": "sameorigin"
        }
      ]
    },
    {
      "source": "/:path*.css",
      "has": [
        {
          "type": "query",
          "key": "authorized"
        }
      ],
      "headers": [
        {
          "key": "x-authorized",
          "value": "true"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "style"
        },
        {
          "key": "X-Frame-Options",
          "value": "sameorigin"
        }
      ]
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "query",
          "key": "authorized"
        }
      ],
      "headers": [
        {
          "key": "x-authorized",
          "value": "true"
        }
      ]
    }
  ]
}
