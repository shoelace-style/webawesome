---
import PageLayout from "../../../layouts/PageLayout.astro"
import * as fs from "node:fs"
import * as path from 'node:path';

export const dir = path.join(process.cwd(), "src", "pages", "page-templates", "advanced-example")

export const html = fs.readFileSync(path.resolve(dir, "_advanced-example.html"))
export const css = fs.readFileSync(path.resolve(dir, "_advanced-example.css"))
---

<style>
  .logo-controls {
    display: none;
  }
</style>

<style set:html={css}></style>

<PageLayout frontmatter={{
  title: "Advanced Example",
  description: "Advanced Example",
}}>
  {html}
</PageLayout>


