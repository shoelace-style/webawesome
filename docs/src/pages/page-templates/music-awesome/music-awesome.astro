---
import PageLayout from "../../../layouts/PageLayout.astro"
import * as fs from "node:fs"
import * as path from 'node:path';

export const dir = path.join(process.cwd(), "src", "pages", "page-templates", "music-awesome")

export const html = fs.readFileSync(path.resolve(dir, "_music-awesome.html"))
export const css = fs.readFileSync(path.resolve(dir, "_music-awesome.css"))
---

<style is:global>
  .logo-controls {
    display: none;
  }
</style>

<style set:html={css}></style>


<PageLayout frontmatter={{
  title: "Sport Awesome",
  description: "Sport Awesome",
}}>
  {html}
</PageLayout>


