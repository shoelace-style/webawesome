---
import PageLayout from "../../../layouts/PageLayout.astro"
import * as fs from "node:fs"
import * as url from 'node:url';
import * as path from 'node:path';

const __dirname = path.join(process.cwd(), "src", "pages", "page-templates", "sport-awesome")

const html = fs.readFileSync(path.resolve(__dirname, "_sport-awesome.html"))
const css = fs.readFileSync(path.resolve(__dirname, "_sport-awesome.css"))
---

<style is:global>
  .logo-controls {
    display: none;
  }
</style>

<style is:global set:html={css}></style>

<PageLayout frontmatter={{
  title: "Sport Awesome",
  description: "Sport Awesome",
}}>
  {html}
</PageLayout>


