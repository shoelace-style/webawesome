<script type="module">
  import "https://esm.run/light-pen"
</script>

<light-pen style="height: 100%; padding: 8px;" resize-position="30">
  <template slot="html">
    {% include html_file %}
  </template>

  <template slot="css">
    @import "/dist/themes/light.css";
    @import "/dist/themes/dark.css";

    {% include css_file %}
  </template>

  <template slot="js">
    import { setBasePath } from "/dist/shoelace.js";
    setBasePath("/dist")
  </template>
</light-pen>
