{% set paletteId = palette.fileSlug or page.fileSlug %}
{% set tints = [10, '', 95] %}
{% set tintStroke = {'95': '80', '10': '30'} %}
{% set tintRow = {'': '1', '10': '0', '95': '0'} %}
{% set rows = 2 %}
{% set tintClass = {'10': 'only-dark', '95': 'only-light'} %}
{% set width = 30 %}
{% set height = 40 %}
{% set gap_x = 8 %}
{% set gap_y = 10 %}

<svg viewBox="{{ -gap_x/2 }} {{ -gap_y/2 }} {{ (width + gap_x) * hues|length + gap_x }} {{ (height + gap_y) * rows + gap_y }}" fill="none" xmlns="http://www.w3.org/2000/svg" class="wa-palette-{{ paletteId }} palette-icon">
<style>
	@import url('/dist/styles/color/{{ paletteId }}.css') layer(palette.{{ paletteId }});
	.palette-icon {
		height: 8ch;
	}

	.palette-swatch {
		width: {{ width }}px;
		height: {{ height }}px;
		rx: 4px;
		stroke-width: 1px;
	}
</style>

{% for hue in hues -%}
  {% set hueIndex = loop.index0 %}
  {% for tint in tints -%}
	{% set suffix = '-' + tint if tint %}
    <rect class="palette-swatch {{ tintClass[tint] }}" x="{{ gap_x/2 + hueIndex * (width + gap_x) }}" y="{{ gap_y/2 + tintRow[tint] * (height + gap_y) }}"
	      fill="var(--wa-color-{{ hue }}{{ '-' + tint if tint }})"
		  stroke="var(--wa-color-{{ hue }}{{ '-' + tintStroke[tint] if tint }})" />
  {%- endfor %}
{% endfor %}
</svg>
