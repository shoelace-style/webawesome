/* Reset */

*, *:before, *:after {
  box-sizing: border-box;
  font-family: var(--wa-font-family-body);
}

html, body {
  height: auto;
  min-height: 100%;
}

body {
  margin: 0;
}

[hidden] {
  display: none !important;
}

p {
  margin: 0;
}

h1,h2,h3,h4,h5,h6 {
  margin: 0;
  padding: 0;
  font-weight: normal;
}

/* Gives us a nice fade-in to prevent layout jank */
:not(:defined) {
  opacity: 0;
}

:defined {
  opacity: 1;
  transition: opacity 100ms ease-in-out;
}
